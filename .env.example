# ── LLM Provider (configure at least one) ────────────────────
# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
# OPENAI_API_KEY=sk-your-key-here

# Google Gemini
# GOOGLE_KEY=your-key-here

# AWS Bedrock
# BEDROCK_AWS_DEFAULT_REGION=us-east-1
# BEDROCK_AWS_ACCESS_KEY_ID=your-key-here
# BEDROCK_AWS_SECRET_ACCESS_KEY=your-secret-here

# Local Ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434


# ── Agent Provider / Model ────────────────────────────────────
# The three pre-built migration agents (Postgres, Snowflake, ClickHouse OSS)
# each default to whichever API key is set above. Override globally or
# per-source. Use LibreChat provider casing exactly:
#   anthropic | openAI | google | bedrock | azureOpenAI
#
# Global default (applies to all three agents unless overridden):
# AGENT_PROVIDER=anthropic
# AGENT_MODEL=claude-sonnet-4-6
#
# Per-source overrides — hyphens in source IDs become underscores:
# AGENT_PROVIDER_POSTGRES=anthropic
# AGENT_MODEL_POSTGRES=claude-sonnet-4-6
# AGENT_PROVIDER_SNOWFLAKE=openAI
# AGENT_MODEL_SNOWFLAKE=gpt-4o
# AGENT_PROVIDER_CLICKHOUSE_OSS=anthropic
# AGENT_MODEL_CLICKHOUSE_OSS=claude-haiku-4-5-20251001
#
# Changing any of these after first start requires `make reset-agent`.
# (Partners can also edit each agent's model directly in the LibreChat UI.)


# ── LibreChat Host URL ────────────────────────────────────────
# Required for OAuth callbacks (e.g. ClickHouse Cloud MCP sign-in).
# On localhost leave these as-is. On a remote server set both to your
# Public URL of this deployment (no trailing slash).
# For remote servers use https:// — artifacts require a secure context (HTTPS).
# Example: https://13.250.15.68  (nginx proxy handles TLS on port 443)
DOMAIN_CLIENT=https://localhost
DOMAIN_SERVER=https://localhost

# ── LibreChat Security (change these before sharing) ─────────
JWT_SECRET=playground-jwt-secret-change-me-32x
JWT_REFRESH_SECRET=playground-refresh-secret-32xx
CREDS_KEY=f34be427ebb29de8d88c107a71546019685ed8b241d8f2ed00c3df97ad2566f0
CREDS_IV=e2341419ec3dd3d19b13a1a87fafcbfb

# ── Langfuse Observability (optional) ────────────────────────
# Traces every LLM call in LibreChat: token usage, latency, full conversation flow.
# Sign up free at https://cloud.langfuse.com → Settings → API Keys
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Dataset Size (small / medium / large) ────────────────────
# small:  ~1M events,  seed ~1 min
# medium: ~10M events, seed ~5-10 min  (default)
# large:  ~30M events, seed ~20-30 min
DATASET_SIZE=medium

# ── ClickHouse OSS Source (set when running migrate.py) ──────
# Defaults match the local Docker service — only override if changed.
# CH_OSS_HOST=localhost
# CH_OSS_PORT=8123
# CH_OSS_USER=default
# CH_OSS_PASSWORD=
# CH_OSS_DB=analytics

# ── ClickHouse Cloud Target ───────────────────────────────────
# Required: set these before running migration scripts OR using the write MCP.
# The clickhousectl-mcp service reads these at startup — restart
# `docker compose up -d clickhousectl-mcp` after changing them.
# CLICKHOUSE_CLOUD_HOST=<your-service>.clickhouse.cloud
# CLICKHOUSE_CLOUD_USER=default
# CLICKHOUSE_CLOUD_PASSWORD=<your-password>
# CLICKHOUSE_CLOUD_DATABASE=default

# ── Snowflake Source (only for the snowflake migration source) ───
# Free trial: https://signup.snowflake.com
# Required to run snowflake-source MCP and the workload setup script.
#   make snowflake-setup   — copies TPC-H tables into MIGRATION_DEMO.RETAIL
#                            and applies Snowflake-specific augmentations
#                            (VARIANT, TIMESTAMP_TZ, Stream, Dynamic Table)
#   make up-snowflake      — starts the snowflake-source MCP container
# SNOWFLAKE_ACCOUNT=<orgname>-<accountname>
# SNOWFLAKE_USER=<user>
# SNOWFLAKE_PASSWORD=<password>
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_ROLE=
